rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn(); // Gecici olarak herkes admin yetkisine sahip olsun (test icin)
    }

    match /blogPosts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ads/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /adSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /comments/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /servicePages/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /websitePages/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /seoSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactMessages/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /dashboard/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /appointments/items/{itemId} {
        allow read, write: if isAdmin();
      }

      match /activities/items/{itemId} {
        allow read, write: if isAdmin();
      }

      match /chatbotConversations/items/{itemId} {
        allow read, write: if isAdmin();
      }
    }

    match /teamMembers/{docId} {
      allow read, write: if isAdmin();
    }

    match /financeAgreements/{docId} {
      allow read, write: if isAdmin();
    }

    match /cases/{docId} {
      allow read, write: if isAdmin();
    }

    match /clients/{docId} {
      allow read, write: if isAdmin();
    }

    match /documents/{docId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
